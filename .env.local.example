# ============================================================
# Nemovizor — Environment Variables
# Zkopírujte tento soubor jako .env.local a vyplňte hodnoty
# ============================================================

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# === Cloudflare R2 (S3-kompatibilní úložiště) ===
# Najdete v: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=nemovizor-media

# Custom domain pro R2 bucket (nastavte v Cloudflare Dashboard → R2 → bucket → Settings → Custom Domains)
# Doporučeno: media.nemovizor.cz → automaticky přes Cloudflare CDN
R2_PUBLIC_URL=https://media.nemovizor.cz

# === Supabase Service Role Key (server-side, bypasses RLS) ===
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Realman Import API ===
# API klíč pro autentizaci Realman webhooků
REALMAN_API_KEY=your-realman-api-key

# === Mapy.cz API ===
NEXT_PUBLIC_MAPY_API_KEY=your-mapy-api-key

# === Gemini AI (Google) ===
# Najdete v: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# === Upstash Redis (optional — rate limiting) ===
# Pokud jsou tyto dva nastaveny, public API rate limiter (/api/properties,
# /api/v1/* atd.) automaticky použije distribuovaný sliding window přes
# @upstash/ratelimit. Správně funguje i na Vercel serverless s více instancemi.
# Pokud NEJSOU nastaveny, rate limiter padá zpět na in-memory mapu
# (per-proces — vhodné pro dev a single-instance deploy).
#
# Najdete v: https://console.upstash.com/ → Databases → REST API
# UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXXXXX...
